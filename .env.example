# Discord Bot Configuration
TOKEN=your_discord_bot_token_here
CLIENT_ID=your_discord_client_id_here
GUILD_ID=your_dev_guild_id_here

# Supabase Configuration
SUPABASE_URL=your_supabase_project_url_here
SUPABASE_ANON_KEY=your_supabase_anon_key_here
SUPABASE_SERVICE_ROLE_KEY=your_supabase_service_role_key_here

# External APIs (Optional or as needed)
GOOGLE_CALENDAR_API_KEY=your_google_calendar_api_key_here
GITHUB_TOKEN=your_github_personal_access_token_here
GOOGLE_CLOUD_SKILLS_BOOST_API_KEY=your_google_cloud_skills_boost_api_key_here

# Bot App Settings
DEFAULT_REMINDER_CRON=0 20 * * *
ARCADE_ROLE_ID=your_discord_arcade_role_id_here
WELCOME_CHANNEL_ID=your_discord_welcome_channel_id_here
INTRODUCTION_CHANNEL_ID=your_discord_introduction_channel_id_here
LOG_LEVEL=info
