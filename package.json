{
  "name": "skills-arcade-bot",
  "version": "0.1.0",
  "description": "Discord bot that facilitates the Google Skills Boost Arcade 2026 program",
  "type": "module",
  "main": "dist/index.js",
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "build": "tsc",
    "start": "node dist/index.js",
    "lint": "eslint src/**/*.ts",
    "format": "prettier --write src/**/*.ts",
    "deploy:commands": "tsx src/deployCommands.ts",
    "deploy:commands:guild": "tsx src/deployCommands.ts --guild",
    "db:seed": "tsx src/db/seed.ts",
    "test": "vitest run",
    "test:unit": "vitest run --dir src/tests/unit"
  },
  "dependencies": {
    "@napi-rs/canvas": "^0.1.51",
    "@supabase/supabase-js": "^2.43.5",
    "axios": "^1.7.2",
    "chalk": "^4.1.2",
    "discord.js": "^14.15.3",
    "dotenv": "^16.4.5",
    "ms": "^2.1.3",
    "node-cron": "^3.0.3",
    "pino": "^9.2.0",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@types/ms": "^0.7.34",
    "@types/node": "^20.14.9",
    "@types/node-cron": "^3.0.11",
    "eslint": "^9.5.0",
    "prettier": "^3.3.2",
    "tsx": "^4.16.0",
    "typescript": "^5.5.2",
    "vitest": "^1.6.0"
  }
}
